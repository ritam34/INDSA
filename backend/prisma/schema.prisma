generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum UserRole{
  ADMIN
  USER
}

model User{
  id String @id @default(uuid())
  name String
  email String @unique
  image String?
  role UserRole @default(USER)
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problems Problem[]
}

enum Difficulty{
  EASY
  MEDIUM
  HARD
}

model Problem{
  id String @id @default(uuid())
  title String
  description String
  difficulty Difficulty @default(EASY)
  tags String[]
  userId String
  example Json
  constraints String
  hints String?
  editorial String?
  testCases Json
  codeSnippets Json
  referencesSolutions Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}